 * @file lz_config.h
 * @brief Auto-generated configuration by CMake. DO NOT EDIT MANUALLY.
 */

#ifndef LZ_CONFIG_H
#define LZ_CONFIG_H

/* ========================================================================= *
 * Architecture and OS Detection
 * ========================================================================= */
#define LZ_ARCH "@LZ_ARCH@"
#define LZ_OS "@LZ_OS@"

/* ========================================================================= *
 * Hardware Constants (Generated by CMake)
 * ========================================================================= */
/** @brief Cache line size (L1/L2) in bytes. Critical for preventing False Sharing. */
#define LZ_CACHE_LINE_SIZE @LZ_CACHE_LINE_SIZE@

/** @brief Base OS page size (e.g., 4KB on x86_64, 16KB on Apple Silicon). */
#define LZ_PAGE_SIZE @LZ_PAGE_SIZE@

/** @brief Huge Page size (e.g., 2MB on x86_64, 32MB on Apple Silicon). */
#define LZ_HUGE_PAGE_SIZE @LZ_HUGE_PAGE_SIZE@

/** @brief Maximum number of supported NUMA nodes. */
#define LZ_MAX_NUMA_NODES @LZ_MAX_NUMA_NODES@

/** @brief Maximum inactive 2MB Chunks a NUMA node will keep in its lock-free cache. */
#define LZ_VMM_MAX_CACHED_CHUNKS @LZ_VMM_MAX_CACHED_CHUNKS@

/** @brief Bit shift required to calculate the Chunk base address (e.g., 21 for 2MB). */
#define LZ_CHUNK_SHIFT @LZ_CHUNK_SHIFT@

/** @brief Maximum size of the remote free batch before forcing an atomic CAS flush. */
#define LZ_BATCH_MAX_SIZE @LZ_BATCH_MAX_SIZE@

/* ========================================================================= *
 * Telemetry and Observability
 * ========================================================================= */
/** @brief Total slots in the Shared Memory telemetry matrix. */
#define LZ_MAX_TELEMETRY_SLOTS @LZ_MAX_TELEMETRY_SLOTS@

/** @brief Number of telemetry shards to prevent thread contention in LSM regions. */
#define LZ_LSM_SLOTS_COUNT @LZ_LSM_SLOTS_COUNT@

/* ========================================================================= *
 * Allocator Tuning
 * ========================================================================= */
/** @brief Threshold in bytes where the POSIX engine switches from Slabs to direct mmap. */
#define LZ_MAX_SLAB_OBJ_SIZE @LZ_MAX_SLAB_OBJ_SIZE@

/* ========================================================================= *
 * Build Profile
 * ========================================================================= */
#cmakedefine LZ_DEBUG_MODE 1

#endif // LZ_CONFIG_H