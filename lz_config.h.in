/**
 * @file config.h
 * @brief Contrato de topología de hardware generado por CMake.
 * @note Sin dependencias del compilador aquí, solo constantes topológicas.
 */
#ifndef LZ_CONFIG_H
#define LZ_CONFIG_H

/* Identificación de Entorno */
#define LZ_ARCH "@LZ_ARCH@"
#define LZ_OS "@LZ_OS@"

/* Límites Físicos del Silicio */
#define LZ_CACHE_LINE_SIZE @LZ_CACHE_LINE_SIZE@
#define LZ_PAGE_SIZE @LZ_PAGE_SIZE@
#define LZ_MAX_CORES @LZ_MAX_CORES@

/* Geometría de Memoria Virtual (VMM) */
#define LZ_HUGE_PAGE_SIZE @LZ_HUGE_PAGE_SIZE@
#define LZ_CHUNK_SHIFT @LZ_CHUNK_SHIFT@
#define LZ_CHUNK_MASK (~((uintptr_t)LZ_HUGE_PAGE_SIZE - 1))

/* Capacidades del Sistema Operativo */
#cmakedefine LZ_HAS_RSEQ 1

#endif /* LZ_CONFIG_H */