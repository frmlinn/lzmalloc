/**
 * @file lz_config.h
 * @brief Hardware Topology Contract.
 * @details This file is auto-generated by CMake based on silicon detection.
 * It contains hardware-specific constants like cache line size and page geometry.
 * @note Strictly no compiler dependencies; provides raw topological constants.
 */
#ifndef LZ_CONFIG_H
#define LZ_CONFIG_H

/** @brief Target CPU architecture identifier. */
#define LZ_ARCH "@LZ_ARCH@"
/** @brief Target Operating System identifier. */
#define LZ_OS "@LZ_OS@"

/* Silicon Physical Constraints */
/** @brief L1/L2 Cache line size. Critical for preventing false sharing. */
#define LZ_CACHE_LINE_SIZE @LZ_CACHE_LINE_SIZE@
/** @brief Base OS page size (usually 4KB or 16KB). */
#define LZ_PAGE_SIZE @LZ_PAGE_SIZE@
/** @brief Maximum number of supported logical cores. */
#define LZ_MAX_CORES @LZ_MAX_CORES@

/* Virtual Memory Management (VMM) Geometry */
/** @brief Huge Page size (e.g., 2MB on x86, 32MB on ARM). */
#define LZ_HUGE_PAGE_SIZE @LZ_HUGE_PAGE_SIZE@
/** @brief Bit shift required for Chunk address resolution. */
#define LZ_CHUNK_SHIFT @LZ_CHUNK_SHIFT@
/** @brief Bitmask for aligning addresses to Huge Page boundaries. */
#define LZ_CHUNK_MASK (~((uintptr_t)LZ_HUGE_PAGE_SIZE - 1))

/* OS Capabilities */
/** @brief Defined if the kernel supports Restartable Sequences (RSEQ). */
#cmakedefine LZ_HAS_RSEQ 1

#endif /* LZ_CONFIG_H */